# ABP HTTP API kökü (boş bırakırsanız geliştirmede /api ve /connect Vite proxy ile gider)
# Doğrudan HTTPS: https://localhost:44373
VITE_ABP_API_URL=

# Site içeriği + blog’u ABP CMS API’den oku/yaz (backend + migrator + token gerekir)
# VITE_USE_CMS_API=true

# React admin paneli şifresi (belirtilmezse kod içi varsayılan: admin123)
VITE_ADMIN_PASSWORD=

# Vite proxy hedefi — ABP HttpApi.Host (launchSettings ile aynı port)
# VITE_ABP_PROXY_TARGET=https://localhost:44373
